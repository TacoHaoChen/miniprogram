.tishi {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 1000rpx;
    width: 100%;
}

.tishi text {
    font-size: 50rpx;
    color: #9eb7dd;
}

.huakuai,.lisisuju {
    height: 100%;
    width: 100%;
}

.lisisuju {
    display: flex;
    flex-wrap: wrap;
}

.tupianlist {
    width: 45%;
    margin: 0 0 3.3% 3.3%;
}

.tupianlist image {
    width: 100%;
    border-radius: 15rpx;
}

.shuomingk {
    width: 100%;
    height: 50rpx;
}

.shuoming,.shuomingk {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.shuoming {
    width: 80%;
}

.shuoming text {
    margin: 0 0 3.3% 3.3%;
}