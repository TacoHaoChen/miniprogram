.layout {
    left: 0rpx;
    right: 0rpx;
    top: 0rpx;
    bottom: 0rpx;
    background-color: #000;
}

.image,.layout,.stage {
    position: absolute;
}

.image {
    width: 100%;
    height: 100%;
}

.box {
    position: absolute;
    border: 4rpx solid grey;
    box-sizing: border-box;
    box-shadow: 0rpx 0rpx 0rpx 2000rpx rgba(0,0,0,.5);
}

.lt {
    top: -6rpx;
    border-top: 12rpx solid #fff;
}

.lb,.lt {
    position: absolute;
    height: 48rpx;
    width: 48rpx;
    left: -6rpx;
    border-left: 12rpx solid #fff;
}

.lb {
    bottom: -6rpx;
    border-bottom: 12rpx solid #fff;
}

.rt {
    top: -6rpx;
    border-top: 12rpx solid #fff;
}

.rb,.rt {
    position: absolute;
    height: 48rpx;
    width: 48rpx;
    right: -6rpx;
    border-right: 12rpx solid #fff;
}

.rb {
    bottom: -6rpx;
    border-bottom: 12rpx solid #fff;
}

.line-v {
    width: 2rpx;
    height: 100%;
}

.line-h,.line-v {
    position: absolute;
    background-color: hsla(0,0%,100%,.5);
}

.line-h {
    height: 2rpx;
    width: 100%;
}