.rele {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.rele .rele_window {
  width: 600rpx;
  height: 862rpx;
  background: white;
  border-radius: 15rpx;
  display: flex;
  flex-direction: column;
}

.rele_window .remove {
  width: 100%;
  padding: 30rpx 20rpx 0 0;
  display: flex;
  justify-content: flex-end;
}

.rele_window .remove>image {
  width: 37rpx;
  margin-right: 30rpx;
}

.rele_window .rele_head {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rele_head>text:nth-child(1) {
  font-size: 36rpx;
  color: #333333;
  font-weight: 900;
}

.rele_head>text:nth-child(2) {
  width: 450rpx;
  font-size: 24rpx;
  color: #666666;
  text-align: center;
  margin-top: 15rpx;
}

.step {
  width: 100%;
  display: flex;
  flex-direction: column;
  padding-left: 60rpx;
  margin-top: 60rpx;
}

.step>text {
  font-size: 30rpx;
  color: #333333;
  font-weight: blod;
}

.step>view {
  display: flex;
  margin-top: 8rpx;
  position: relative;
}

.step>view:nth-child(2) {
  margin-top: 30rpx;
}

.step>view .circle {
  width: 15rpx;
  height: 15rpx;
  background-image: linear-gradient(to left,#3d35ff,#615df0);
  border-radius: 50%;
  position: absolute;
  top: 12rpx;
}

.step>view .stepFont {
  width: 476rpx;
  font-size: 28rpx;
  color: #333333;
  font-weight: blod;
  padding-left: 30rpx;
  line-height: 40rpx;
}

.copyID {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.copyID>text {
  width: 402rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-image: linear-gradient(to right,#3d35ff,#615df0);
  color: white;
  font-size: 30rpx;
  border-radius: 10rpx;
  letter-spacing: 2rpx;
}



