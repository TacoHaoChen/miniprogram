  border-radius: 30rpx;
}

.listItemPhoneScreen {
  width: 90%;
  height: 300rpx;
  line-height: 300rpx;
  display: inline-block;
  background: #000;
  margin: 15rpx 5%;
}

.listItemPhoneTxt {
  color: #fff;
  text-shadow: 0 0 6px #e91e63,0 0 8px #e91e63,0 0 12px #e91e63,0 0 17px #e91e63;
  font-size: 88rpx;
  text-align: center;
}

.typeShowImgAd {
  width: 100%;
  border-radius: 10rpx;
}

.twinkleColorBox {
  margin: 15rpx 5%;
  width: 90%;
  height: 300rpx;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
  background: rgba(223,163,163,0.5);
  transition: background 0.2s linear;
  animation: bgColorChange 1s linear infinite;
}

@-webkit-keyframes bgColorChange {
  0% {
      background: rgb(255,192,75);
  }

  25% {
      background: rgb(255,63,63);
  }

  50% {
      background: rgb(51,255,95);
  }

  75% {
      background: rgb(61,216,255);
  }

  100% {
      background: rgb(249,84,255);
  }
}

@keyframes bgColorChange {
  0% {
      background: rgb(255,192,75);
  }

  25% {
      background: rgb(255,63,63);
  }

  50% {
      background: rgb(51,255,95);
  }

  75% {
      background: rgb(61,216,255);
  }

  100% {
      background: rgb(249,84,255);
  }
}

.letterLine {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 330rpx;
  overflow: hidden;
}

.letterLine.word {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 330rpx;
  overflow: hidden;
  z-index: 10;
  font-size: 88rpx;
  color: #fff;
  letter-spacing: 2rpx;
  white-space: nowrap;
  text-align: center;
  line-height: 192rpx;
  text-shadow: 2px 2px 3px #03a9f4,2px 2px 6px #03a9f4,-2px -2px 3px #03a9f4,-2px -2px 6px #03a9f4,2px -2px 3px #03a9f4,2px -2px 6px #03a9f4,-2px 2px 3px #03a9f4,-2px 2px 6px #03a9f4;
}

.letterInfo {
  position: absolute;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
  font-size: 88rpx;
  color: #fff;
  letter-spacing: 2rpx;
  white-space: nowrap;
}

