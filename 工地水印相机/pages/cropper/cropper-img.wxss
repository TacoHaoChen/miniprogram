page {
    box-sizing: border-box;
}

.body,page {
    height: 100%;
}

.body {
    display: flex;
    flex-direction: column;
}

.stage {
    flex-grow: 1;
}

.bar {
    height: 80rpx;
    padding: 36rpx;
    display: flex;
    flex-direction: row;
    background-color: #000;
}

.xuanzhe {
    width: 50%;
}

.paizhao text,.xuanzhe {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100rpx;
}

.paizhao text {
    width: 100%;
    line-height: 100rpx;
    font-size: 50rpx;
    color: #6aa1e0;
}

.paizhao {
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    border: 10rpx solid #c6e0f1;
}