.page,.yemian {
    height: 100%;
    width: 100%;
}

.yemian {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.xianji,.xianji camera,.xianji image {
    width: 100%;
}

.shuiyingkuan {
    position: absolute;
    bottom: 17rpx;
    left: 17rpx;
}

.shuiyin text {
    height: 10rpx;
    line-height: 10rpx;
    color: #fff;
    font-size: 28rpx;
}

.dingwei {
    position: absolute;
    bottom: 17rpx;
    right: 17rpx;
}

.tubiao {
    display: flex;
    flex-direction: column;
    text-align: center;
    height: 60rpx;
    line-height: 60rpx;
    color: #fff;
    font-size: 60rpx;
}

.dingweitishi {
    height: 10rpx;
    line-height: 10rpx;
    color: #fff;
    font-size: 28rpx;
}

.xiamian {
    height: 100rpx;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.kongzhi,.xiamian {
    display: flex;
    width: 100%;
}

.kongzhi {
    height: 150rpx;
}

.tubiaokuan {
    width: 15%;
}

.tubiaokuan,.tubiaokuan text {
    display: flex;
    flex-direction: column;
    text-align: center;
    height: 200rpx;
    line-height: 200rpx;
}

.tubiaokuan text {
    color: #00b7ff;
    font-size: 60rpx;
}

.yuan {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 40%;
    height: 161rpx;
}

.paizhao {
    width: 91rpx;
    height: 91rpx;
    border-radius: 50%;
    border: 10rpx solid #0582d6;
}

.panzhaojian {
    display: flex;
    flex-direction: column;
    text-align: center;
    width: 33%;
    height: 100rpx;
}

.panzhaojian text {
    width: 100%;
    height: 100rpx;
    line-height: 100rpx;
    font-size: 90rpx;
}

.baochun {
    width: 100%;
}

.baochun,.xuanzhe {
    display: flex;
    height: 150rpx;
}

.xuanzhe {
    width: 50%;
}

.paizhao text,.xuanzhe {
    flex-direction: column;
    align-items: center;
    justify-content: center;
}

.paizhao text {
    display: flex;
    width: 100%;
    height: 100rpx;
    line-height: 100rpx;
    font-size: 70rpx;
    color: #059753;
}