}

.shaizi-box {
    position: relative;
    width: 90%;
    height: 890rpx;
    margin: 0 auto;
    border-radius: 12rpx;
}

.sz-box {
    position: relative;
    height: 50%;
}

.sz-resultImg {
    position: absolute;
    right: 10%;
    top: 50%;
    transform: translateY(-50%);
}

.sz-resultImg image {
    width: 112rpx;
    height: 96rpx;
}

.outer {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100%;
    perspective: 500rpx;
    perspective-origin: 50% 50%;
    overflow: hidden;
    transform: scale(.9);
}

.group {
    width: 200rpx;
    height: 200rpx;
    transform-style: preserve-3d;
    transform-origin: 50% 50% -100rpx;
    transform: rotateY(0deg) rotateX(90deg) rotateZ(36deg);
    background-color: #e8e8e9;
    border-radius: 20rpx;
}

.group.active1 {
    animation: scroll1 .8s linear 0s forwards;
}

.group.active2 {
    animation: scroll2 .8s linear 0s forwards;
}

.group.active3 {
    animation: scroll3 .8s linear 0s forwards;
}

.group.active4 {
    animation: scroll4 .8s linear 0s forwards;
}

.group.active5 {
    animation: scroll5 .8s linear 0s forwards;
}

.group.active6 {
    animation: scroll6 .8s linear 0s forwards;
}

.mpage {
    width: 200rpx;
    height: 200rpx;
    position: absolute;
    border-radius: 20rpx;
    font-weight: 700;
    overflow: hidden;
    word-break: break-all;
    word-wrap: break-word;
    text-align: center;
    background-color: #e8e8e9;
}

.page2 {
    transform-origin: right;
    transform: rotateY(-90deg);
}

.page3 {
    transform-origin: left;
    transform: rotateY(90deg);
}

.page4 {
    transform-origin: top;
    transform: rotateX(-90deg);
}

.page5 {
    transform-origin: bottom;
    transform: rotateX(90deg);
}

.page6 {
    transform: translateZ(-200rpx);
}

.mpage .dot {
    display: inline-block;
    width: 50rpx;
    height: 50rpx;
    border-radius: 25rpx;
    background-color: #050505;
}

.page1 .dot {
    position: absolute;
    left: 50%;
    top: 50%;
    margin-top: -25rpx;
    margin-left: -25rpx;
    background-color: #bc3132;
}

.sz-red .mpage {
    background: #c20000;
}

.sz-red .dot,.sz-red .page1 .dot {
    background: #fff;
}

.page2 .dot {
    margin: 75rpx 25rpx;
}

.page3 .dot {
    position: absolute;
}

.page3 .dot:first-child {
    top: 20rpx;
    left: 20rpx;
}

.page3 .dot:nth-child(2) {
    top: 75rpx;
    left: 75rpx;
}

.page3 .dot:last-child {
    bottom: 20rpx;
    right: 20rpx;
}

.page4 .dot,.page5 .dot {
    margin: 25rpx;
}

.page5 .dot:last-child {
    position: absolute;
    top: 50%;
    left: 50%;
    margin-left: -25rpx;
    margin-top: -25rpx;
}

.page6 .dot {
    margin: 12rpx 25rpx;
    width: 40rpx;
    height: 40rpx;
    border-radius: 20rpx;
}

@-webkit-keyframes scroll1 {
    0% {
        transform: rotateY(0deg) rotateX(40deg) rotateZ(0deg);
    }

    99% {
        transform: rotateY(4turn) rotateX(40deg) rotateZ(50deg);
    }

    to {
        transform: rotateY(0deg) rotateX(0) rotateZ(0);
    }
}

@keyframes scroll1 {
    0% {
        transform: rotateY(0deg) rotateX(40deg) rotateZ(0deg);
    }

    99% {
        transform: rotateY(4turn) rotateX(40deg) rotateZ(50deg);
    }

    to {
        transform: rotateY(0deg) rotateX(0) rotateZ(0);
    }
}

