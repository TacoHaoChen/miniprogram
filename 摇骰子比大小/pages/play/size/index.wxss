.muiscIcon {
    position: absolute;
    right: 5%;
    width: 40rpx;
    height: 40rpx;
    background-size: 40rpx 40rpx;
    z-index: 3;
    animation: muiscFrames 3s linear infinite;
    margin-top: 48rpx;
}

@-webkit-keyframes muiscFrames {
    0% {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(1turn);
    }
}

@keyframes muiscFrames {
    0% {
        transform: rotate(0deg);
    }

    to {
        transform: rotate(1turn);
    }
}

.muiscIcon.no {
    background-size: 40rpx 40rpx;
    animation: none;
}

.active {
    transition: all .6s ease-out;
    transform: translateY(-2000rpx) rotate(-90deg);
}

