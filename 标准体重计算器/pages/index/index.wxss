.result {
    background-color: #327739;
    box-shadow: 2px 2px 6px #999;
    margin-bottom: 9px;
    width: 100%;
}

.result .title {
    color: #f1f1f1;
    font-size: 28rpx;
    font-weight: 600;
    padding: 20rpx 40rpx 0;
}

.result .score {
    color: #fff;
    font-size: 60rpx;
    line-height: 100rpx;
    padding: 0 40rpx;
}

.tip {
    display: flex;
}

.first-tip {
    margin-bottom: 4rpx;
}

.tip view {
    background-color: #327739;
    color: #f1f1f1;
    flex: 1;
    font-size: 24rpx;
    line-height: 80rpx;
    padding-left: 40rpx;
}

.tip view text {
    color: #fff;
}

.physical-condition {
    margin: 0 4rpx 0 0;
}

.input-container {
    padding: 0 40rpx;
}

.item {
    border-bottom: 1px solid #e2e2e2;
    color: #909090;
    font-size: 32rpx;
    height: 56rpx;
    line-height: 56rpx;
    padding: 20rpx 0rpx;
}

.item .label {
    float: left;
    vertical-align: middle;
    width: 20%;
}

.item input {
    background-color: #f1f1f1;
    border: 1rpx solid #d9d9d9;
    border-radius: 6rpx;
    color: #327739;
    height: 40rpx;
    margin-left: 30%;
    margin-right: 10%;
    padding-right: 8rpx;
    text-align: right;
}

.item .type_select,.item .unit {
    float: right;
}

.item .type_select text {
    margin-left: 8rpx;
}

.no-border {
    border-bottom: 0;
}

.calcu_btn {
    background-color: #327739;
    box-shadow: 2px 2px 4px #999;
    color: #fff;
    font-weight: 400;
}

#result-container {
    padding: 20rpx 0;
}

.compatable {
    color: #909090;
    font-size: 28rpx;
    padding: 40rpx 40rpx 0;
}

.compatable .table-title {
    height: 50rpx;
    line-height: 50rpx;
}

.table {
    border: 1rpx solid #e2e2e2;
    box-shadow: 1px 2px 4px #ccc;
}

.table .row {
    border-bottom: 1rpx solid #e2e2e2;
    display: flex;
    height: 60rpx;
    line-height: 60rpx;
}

.table .row .col {
    border-right: 1rpx solid #e2e2e2;
    flex: 1;
    text-align: center;
}

.table .thead {
    background-color: #327739;
    color: #f1f1f1;
}

.table .row .col:last-child {
    border-right: 0rpx;
}

.table .row:last-child {
    border-bottom: 0rpx;
}

.ad {
    color: #327739;
    margin-bottom: 5px;
    margin-top: 20px;
    text-align: center;
}

.ad_style {
    border-bottom: 5px solid #327739;
    border-top: 5px solid #327739;
    margin-top: 10px;
}




.sharebox {
    /* background: #2C86F7; */
    border: 3px solid #327739;
    width: 51%;
    margin: auto;
    border-radius: 30rpx;
    height: 100rpx;
    align-items: center;
    color: #1b9e69;
}


.sharebutton {
    color: #327739;
    line-height: 69rpx;
    margin-left: 0rpx;
    margin-top: 2rpx;
    font-size: 36rpx;
}